{
  "id": "openclaw-channel-minion",
  "name": "Minion Channel",
  "channels": [
    "minion"
  ],
  "description": "Connects ESP32-based Minion robots to OpenClaw via WebSocket. Supports xiaozhi-esp32 firmware protocol with Bearer + HMAC authentication, IP allowlist, and per-device secret rotation.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "port": {
        "type": "integer",
        "default": 8788,
        "description": "WebSocket server port"
      },
      "path": {
        "type": "string",
        "default": "/minion",
        "description": "WebSocket route path"
      },
      "requireHmac": {
        "type": "boolean",
        "default": true,
        "description": "Require HMAC signature on every inbound message"
      },
      "timestampToleranceSec": {
        "type": "integer",
        "default": 60,
        "description": "Max clock skew window for replay protection (seconds)"
      },
      "rateLimit": {
        "type": "object",
        "properties": {
          "perDevicePerMinute": {
            "type": "integer",
            "default": 60
          }
        },
        "additionalProperties": false
      },
      "asr": {
        "type": "object",
        "description": "ASR provider config. Selects backend by 'provider'.",
        "required": [
          "provider"
        ],
        "properties": {
          "provider": {
            "enum": [
              "local-whisper",
              "aliyun-paraformer",
              "openai-whisper-api",
              "xfyun"
            ]
          },
          "url": {
            "type": "string"
          },
          "timeoutMs": {
            "type": "integer"
          },
          "apiKey": {
            "type": "string"
          },
          "apiKeyFile": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "taskTimeoutMs": {
            "type": "integer"
          },
          "heartbeat": {
            "type": "boolean"
          },
          "appId": {
            "type": "string"
          },
          "apiSecret": {
            "type": "string"
          },
          "audioFormat": {
            "enum": [
              "opus",
              "pcm"
            ]
          }
        },
        "additionalProperties": false
      },
      "tts": {
        "type": "object",
        "description": "TTS provider config. Selects backend by 'provider'.",
        "required": [
          "provider"
        ],
        "properties": {
          "provider": {
            "enum": [
              "edge",
              "aliyun-cosyvoice",
              "openai-tts",
              "volcengine"
            ]
          },
          "voice": {
            "type": "string"
          },
          "rate": {
            "type": "string"
          },
          "pitch": {
            "type": "string"
          },
          "apiKey": {
            "type": "string"
          },
          "apiKeyFile": {
            "type": "string"
          },
          "appId": {
            "type": "string",
            "description": "Volcengine app id (火山引擎应用ID)"
          },
          "cluster": {
            "type": "string",
            "description": "Volcengine TTS cluster (volcano_tts | volcano_icl)"
          },
          "speedRatio": {
            "type": "number",
            "description": "Speed ratio 0.8-2.0, default 1.0"
          },
          "loudnessRatio": {
            "type": "integer",
            "description": "v3 `loudness_rate` integer offset (NOT a ratio despite the name). 0=default, ~20=sweet spot (+2 dB peak), ~50=server-side soft-limit kicks in (+3 dB max). Use to make vv 2.0 / *_uranus_bigtts voices match wanwan moon loudness."
          },
          "timeoutMs": {
            "type": "integer"
          },
          "resourceId": {
            "type": "string",
            "description": "Volcengine TTS 2.0 resource id (default: volc.service_type.10029 for 大模型语音合成 2.0)"
          },
          "emotion": {
            "type": "string",
            "description": "Voice emotion: happy / sad / angry / surprised / fear / hate / excited / coldness / neutral (requires *_bigtts voice)"
          },
          "enableEmotion": {
            "type": "boolean",
            "description": "Enable emotion synthesis (auto-true when emotion is set)"
          }
        },
        "additionalProperties": false
      },
      "devices": {
        "type": "object",
        "description": "Map of device_id to device config. Each device has its own secret + sessionKey.",
        "additionalProperties": {
          "type": "object",
          "required": [
            "secret",
            "sessionKey"
          ],
          "properties": {
            "secret": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "required": [
                    "source",
                    "id"
                  ],
                  "properties": {
                    "source": {
                      "enum": [
                        "env",
                        "file"
                      ]
                    },
                    "id": {
                      "type": "string"
                    }
                  }
                }
              ]
            },
            "sessionKey": {
              "type": "string"
            },
            "allowedIps": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "CIDR ranges or single IPs allowed to connect"
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "channelEnvVars": [],
  "activation": {
    "onStartup": true
  },
